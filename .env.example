# ============================================
# ПРИМЕР ФАЙЛА ПЕРЕМЕННЫХ ОКРУЖЕНИЯ
# ============================================
# 
# Скопируйте этот файл в .env.local для локальной разработки:
#   cp .env.example .env.local
#
# ВАЖНО: Никогда не коммитьте .env файлы с реальными данными!
# ============================================

# ============================================
# Firebase Configuration
# ============================================
# Получите credentials из Firebase Console:
# 1. Перейдите в Project Settings > Service Accounts
# 2. Generate New Private Key
# 3. Скопируйте данные из JSON файла

FIREBASE_PROJECT_ID=fullstackforge-6618e
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@fullstackforge-6618e.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\na35b539b7c2aa32bfd6af0c0f5ed806b955e64ef\n-----END PRIVATE KEY-----\n"

# ============================================
# Firebase Configuration (Frontend/Public)
# ============================================
# Получите конфигурацию из Firebase Console:
# Project Settings > Your apps > Web App конфигурация

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAP8iy8ti7XGtP_mcGD8GoYYD3Fb0PWbPo
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=fullstackforge-6618e.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=fullstackforge-6618e
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=fullstackforge-6618e.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=841803620012
NEXT_PUBLIC_FIREBASE_APP_ID=1:841803620012:web:cbdc104e83d1b3eaaa0909
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-BVBSDGXM77

# ============================================
# Authentication (NextAuth.js)
# ============================================
# Сгенерируйте хеш пароля: node -e "const bcrypt=require('bcrypt');bcrypt.hash('your_password',10).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$10$XeV94RQhC630yo1J3Qc9Wu/4f4oDNFaJYgHhmnHTxjgOTmcUayALO

# Сгенерируйте secret: openssl rand -base64 32
AUTH_SECRET=pY5gK8mN4tV7yB1wE3sH6aD9fG0hJ2kL3mN4oP5qR6s=

# ============================================
# Application URLs
# ============================================
# Для локальной разработки:
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Для production (Firebase Hosting):
# NEXT_PUBLIC_BASE_URL=https://fullstackforge-6618e.web.app
# NEXTAUTH_URL=https://fullstackforge-6618e.web.app

# ============================================
# Cron Jobs (опционально)
# ============================================
CRON_SECRET=your_cron_secret_key

# ============================================
# UploadThing (File Upload Service)
# ============================================
# Получите ключи на https://uploadthing.com/dashboard
# 1. Создайте аккаунт
# 2. Создайте новое приложение
# 3. Скопируйте App ID и Secret Key

UPLOADTHING_APP_ID=your_uploadthing_app_id
UPLOADTHING_TOKEN=your_uploadthing_token

# ============================================
# Application Settings
# ============================================

# Node окружение (development | production | test)
NODE_ENV=development

# Порт приложения (по умолчанию 3000, не используется для Firebase Hosting)
PORT=3000
