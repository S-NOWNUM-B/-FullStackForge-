# ============================================
# ПРИМЕР ФАЙЛА ПЕРЕМЕННЫХ ОКРУЖЕНИЯ
# ============================================
# 
# Скопируйте этот файл в .env.local для локальной разработки:
#   cp .env.example .env.local
#
# ВАЖНО: Никогда не коммитьте .env файлы с реальными данными!
# ============================================

# ============================================
# Firebase Configuration
# ============================================
# Получите credentials из Firebase Console:
# 1. Перейдите в Project Settings > Service Accounts
# 2. Generate New Private Key
# 3. Скопируйте данные из JSON файла

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"

# ============================================
# Authentication (NextAuth.js)
# ============================================
# Сгенерируйте хеш пароля: node -e "const bcrypt=require('bcrypt');bcrypt.hash('your_password',10).then(console.log)"
ADMIN_PASSWORD_HASH=your_hashed_password_here

# Сгенерируйте secret: openssl rand -base64 32
AUTH_SECRET=your_secret_key_min_32_characters_long

# ============================================
# Application URLs
# ============================================
# Для локальной разработки:
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Для production (Firebase Hosting):
# NEXT_PUBLIC_BASE_URL=https://your-domain.web.app
# NEXTAUTH_URL=https://your-domain.web.app

# ============================================
# Cron Jobs (опционально)
# ============================================
CRON_SECRET=your_cron_secret_key

# ============================================
# UploadThing (File Upload Service)
# ============================================
# Получите ключи на https://uploadthing.com/dashboard
# 1. Создайте аккаунт
# 2. Создайте новое приложение
# 3. Скопируйте App ID и Secret Key

UPLOADTHING_APP_ID=your_uploadthing_app_id
UPLOADTHING_TOKEN=your_uploadthing_token

# ============================================
# Application Settings
# ============================================

# Node окружение (development | production | test)
NODE_ENV=development

# Порт приложения (по умолчанию 3000, не используется для Firebase Hosting)
PORT=3000
